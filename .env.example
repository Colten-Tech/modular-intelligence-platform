# ─────────────────────────────────────────────────────────────────────────────
# Modular Intelligence Platform — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # service_role key — KEEP SECRET
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...     # anon/public key — safe for frontend

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Create a database at https://upstash.com → copy the Redis URL
REDIS_URL=rediss://default:PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# ── Anthropic ─────────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Resend (email) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_...

# ── Stripe ────────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
# Use TEST keys (sk_test_...) during development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...     # From: stripe listen --forward-to localhost:8000/api/billing/webhook
# Create products + prices in Stripe dashboard, copy the price IDs
STRIPE_PRICE_PRO=price_...          # Pro plan monthly
STRIPE_PRICE_TEAM=price_...         # Team plan monthly

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=mip-files

# ── URLs ──────────────────────────────────────────────────────────────────────
# Local development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Production (set these in Koyeb env vars after first deploy)
# APP_URL=https://YOUR_APP.vercel.app
# API_URL=https://YOUR_APP.koyeb.app
# EXTRA_CORS_ORIGINS=https://YOUR_APP.vercel.app,https://YOUR_CUSTOM_DOMAIN.com

# ── Frontend (Next.js public vars) ────────────────────────────────────────────
# These go in Vercel's environment variable settings
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# NEXT_PUBLIC_API_URL=https://YOUR_APP.koyeb.app
